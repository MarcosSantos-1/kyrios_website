rules_version = '2';

// Regras de segurança do Firestore para a Kyrios.
//
// Como aplicar:
// 1. Firebase Console → Firestore Database → Rules
// 2. Cole este arquivo inteiro e publique.
//
// Como adicionar/remover admins:
// - Edite a função isAdmin() abaixo e adicione/remova e-mails.
// - O frontend (NEXT_PUBLIC_ADMIN_EMAILS no .env.local) controla quem
//   consegue ver o /admin; estas regras controlam quem realmente consegue
//   escrever no banco.

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email in [
        "marcosv.dev@outlook.com"
        // Adicione outros admins aqui, separados por vírgula:
        // , "contato@kyrios3d.com"
      ];
    }

    // Catálogo: leitura pública, escrita só admin.
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Depoimentos: leitura pública, escrita só admin.
    match /testimonials/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Configuração geral do site (vitrine, promoção, hero stats).
    match /siteConfig/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Mensagens de contato:
    // - qualquer um pode CRIAR (futuro formulário público envia)
    // - leitura e deleção só admin
    match /messages/{id} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Bloqueia tudo o resto por padrão.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
